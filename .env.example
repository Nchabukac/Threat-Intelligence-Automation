# Threat Intelligence Automation — API Keys
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
#
# The .env file is git-ignored — never commit real keys.

# AlienVault OTX — sign up at https://otx.alienvault.com/
OTX_API_KEY=your-alienvault-otx-key

# AbuseIPDB — sign up at https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=your-abuseipdb-key

# URLhaus — sign up at https://urlhaus.abuse.ch/api/

# ThreatFox — sign up at https://threatfox.abuse.ch/api/

# ThreatFox and UrlHaus key
ABUSE_CH_API_KEY=abusech-key

# VirusTotal — disabled by default (free tier: 4 req/min)
# Uncomment if you have an elevated API tier.
# VIRUSTOTAL_API_KEY=your-virustotal-key
